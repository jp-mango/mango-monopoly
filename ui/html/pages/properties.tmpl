{{define "title"}}Properties{{end}}

{{define "main"}}
<div class="container mx-auto py-8">
	<div class="px-4 sm:px-0">
		<h3 class="text-base font-semibold leading-7 text-gray-900">Upcoming Sales</h3>
		<p class="mt-1 max-w-2xl text-sm leading-6 text-gray-500">List of upcoming sales.</p>
	</div>

	<div class="mt-6 border-t border-gray-100">
		<dl class="divide-y divide-gray-100">
			<div class="py-6">
				<ul role="list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
					{{range .Properties}}
					<li class="bg-white rounded-lg shadow-md p-4 flex flex-col justify-between">
						<div class="text-sm">
							<p class="font-medium text-gray-900">{{.Address.String}}</p>
							<p class="text-gray-500">
								${{FormatMoney .FairMarketValue.Int64}} | {{.PropertyType.String}}
							</p>
						</div>
						<div class="mt-2">
							<a href="/property/{{.ID}}" class="text-primary font-medium hover:text-secondary">View</a>
						</div>
					</li>
					{{end}}
				</ul>
			</div>
		</dl>
	</div>
</div>
{{end}}