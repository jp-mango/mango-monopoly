<!-- JavaScript for toggling the property menu and flipping the arrow -->
<script>
	const propertyMenuButton = document.getElementById('property-menu-button');
	const propertyMenu = document.getElementById('property-menu');
	const propertyArrow = document.getElementById('property-arrow');

	propertyMenuButton.addEventListener('click', () => {
		propertyMenu.classList.toggle('hidden'); // Show/hide the property submenu
		propertyArrow.classList.toggle('rotate-180'); // Rotate the arrow
	});

	// Close the menu if you click outside
	window.addEventListener('click', function (e) {
		if (!propertyMenuButton.contains(e.target) && !propertyMenu.contains(e.target)) {
			propertyMenu.classList.add('hidden');
			propertyArrow.classList.remove('rotate-180'); // Reset the arrow
		}
	});
</script>
